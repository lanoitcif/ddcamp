  "scenes": [
    {
      "id": "bakery",
      "title": "Mrs. Crumb's Bakery",
      "description": "The smell of honey and cinnamon fills the air... but the Sun-Cakes are gone! Mrs. Crumb (a stout halfling with flour on her nose) is distraught.",
      "image": "https://images.unsplash.com/photo-1509440159596-0249088772ff?auto=format&fit=crop&w=1200&q=80",
      "chapter": "Ch 1 \u00b7 Oakhaven Village"
    },
    {
      "id": "market",
      "title": "Oakhaven Market Square",
      "description": "The cobblestone square bustles with vendors selling enchanted trinkets, roasted chestnuts, and colorful festival banners. A frantic merchant waves you over \u2014 his delivery cart has been raided too!",
      "image": "https://images.unsplash.com/photo-1555921015-5532091f6026?auto=format&fit=crop&w=1200&q=80",
      "chapter": "Ch 1 \u00b7 Oakhaven Village"
    },
    {
      "id": "woods",
      "title": "The Sparkle Woods",
      "description": "The trees glow like emeralds and the wind whispers secrets. Hoot the Riddle-Owl (wearing tiny spectacles) blocks your path.",
      "image": "https://images.unsplash.com/photo-1441974231531-c6227db76b6e?auto=format&fit=crop&w=1200&q=80",
      "chapter": "Ch 2 \u00b7 The Sparkle Woods"
    },
    {
      "id": "glade",
      "title": "The Fairy Glade",
      "description": "Sunbeams pierce the canopy like golden pillars. Tiny glowing lights dance between wildflowers \u2014 these are the Glade Fairies, and their firefly lanterns have escaped!",
      "image": "https://images.unsplash.com/photo-1448375240586-882707db888b?auto=format&fit=crop&w=1200&q=80",
      "chapter": "Ch 2 \u00b7 The Sparkle Woods"
    },
    {
      "id": "stream",
      "title": "The Glimmer Stream",
      "description": "A wide stream of liquid silver cuts through the forest. Smooth stones poke above the surface, glittering with embedded crystals. One wrong step means a splash!",
      "image": "https://images.unsplash.com/photo-1470071459604-3b5ec3a7fe05?auto=format&fit=crop&w=1200&q=80",
      "chapter": "Ch 2 \u00b7 The Sparkle Woods"
    },
    {
      "id": "goblin_camp",
      "title": "Goblin Hollow",
      "description": "Ramshackle tents and crooked lanterns fill a forest clearing. The goblins aren't evil \u2014 they're just hungry and scared. Their leader, Grumbletooth, sits on a barrel throne eating a stolen Sun-Cake.",
      "image": "https://images.unsplash.com/photo-1542273917363-3b1817f69a2d?auto=format&fit=crop&w=1200&q=80",
      "chapter": "Ch 2 \u00b7 The Sparkle Woods"
    },
    {
      "id": "caves",
      "title": "The Crystal Caverns",
      "description": "Thousands of crystals line the cave walls, each humming a faint musical note. Touching them in the right order reveals hidden passages. Crystal bats flutter between stalactites overhead.",
      "image": "https://images.unsplash.com/photo-1504870712474-3d4eb38a0e56?auto=format&fit=crop&w=1200&q=80",
      "chapter": "Ch 3 \u00b7 The Mountain Path"
    },
    {
      "id": "bridge",
      "title": "The Skythread Bridge",
      "description": "An ancient rope bridge stretches across a misty chasm. The planks creak and sway with every step. Strange wisps of shadow dance beneath it, whispering forgotten names.",
      "image": "https://images.unsplash.com/photo-1545558014-8692077e9b5c?auto=format&fit=crop&w=1200&q=80",
      "chapter": "Ch 3 \u00b7 The Mountain Path"
    },
    {
      "id": "camp",
      "title": "Moonlit Campfire",
      "description": "A sheltered clearing beneath ancient pines. The fire crackles warmly as stars fill the sky above. This is a safe place to rest, tell stories, and gaze at the constellations.",
      "image": "https://images.unsplash.com/photo-1504851149312-7a075b496cc7?auto=format&fit=crop&w=1200&q=80",
      "chapter": "Ch 3 \u00b7 The Mountain Path"
    },
    {
      "id": "ruins",
      "title": "The Forgotten Shrine",
      "description": "Moss-covered stone pillars form a circle around a cracked altar. Ancient runes glow faintly beneath the ivy. A massive Stone Guardian stands motionless \u2014 until someone approaches the altar.",
      "image": "https://images.unsplash.com/photo-1518709766631-a6a7f45921c3?auto=format&fit=crop&w=1200&q=80",
      "chapter": "Ch 4 \u00b7 The Summit"
    },
    {
      "id": "peak",
      "title": "Whispering Peak",
      "description": "The wind sounds like soft singing. Inside a cozy cave, you find Glint the Dragon licking frosting off his claws. He looks up with big golden eyes \u2014 scared, not scary.",
      "image": "https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?auto=format&fit=crop&w=1200&q=80",
      "chapter": "Ch 4 \u00b7 The Summit"
    },
    {
      "id": "celebration",
      "title": "Festival of Heroes",
      "description": "Oakhaven glows with lanterns and streamers! Mrs. Crumb has baked a dragon-shaped cake. The whole village cheers as the heroes return. Glint sits happily beside the bakery, wearing a tiny chef hat.",
      "image": "https://images.unsplash.com/photo-1533174072545-7a4b6ad7a6c3?auto=format&fit=crop&w=1200&q=80",
      "chapter": "Ch 4 \u00b7 The Summit"
    }
  ],
